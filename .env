DB_USER=sa
DB_PASSWORD=StrongPassword@123
DB_SERVER=localhost
DB_DATABASE=ServerInventory
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Active Directory / LDAP Settings
AD_ENABLED=false
AD_MOCK=false
AD_URL=ldap://localhost:389
AD_BASE_DN=dc=scout,dc=local

# Local Authentication Fallback settings (used if AD_ENABLED=false)
# If LOCAL_AUTH_PASSWORD is left empty, any password is accepted for any username.
LOCAL_AUTH_PASSWORD=
LOCAL_ADMIN_USERS=adminuser,admin,ajay,ajay2
AD_DOMAIN_SUFFIX=@scout.local
AD_USER_DN_PATTERN=cn={username},ou=users,dc=scout,dc=local
AD_ADMIN_USER=cn=admin,dc=scout,dc=local
AD_ADMIN_PASSWORD=AdminPassword123

# Access Control Configuration: only users in this group can update server details.
AD_WRITE_GROUPS=ServerScout-Admins

JWT_SECRET=super-secure-server-scout-jwt-key
