DB_USER=sa
DB_PASSWORD=StrongPassword@123
DB_SERVER=localhost
DB_DATABASE=ServerInventory
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Active Directory / LDAP Settings
AD_MOCK=false
AD_URL=ldap://localhost:389
AD_BASE_DN=dc=scout,dc=local
AD_DOMAIN_SUFFIX=@scout.local
AD_USER_DN_PATTERN=cn={username},ou=users,dc=scout,dc=local
AD_ADMIN_USER=cn=admin,dc=scout,dc=local
AD_ADMIN_PASSWORD=AdminPassword123
# Users in these AD groups can write/edit. Others are read-only.
AD_WRITE_GROUPS=ServerScout-Admins,ServerScout-Writers
JWT_SECRET=super-secure-server-scout-jwt-key
