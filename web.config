<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Configure iisnode handler for server.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Do not rewrite Node inspector requests -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug" />
        </rule>

        <!-- Route all other requests to server.js -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <!-- Keep sensitive folder and config hidden -->
          <add segment="node_modules" />
          <add segment="scratch" />
          <add segment=".git" />
          <add segment=".agents" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Configure node environment (optional debug settings) -->
    <iisnode 
      node_env="production"
      loggingEnabled="true"
      devErrorsEnabled="true"
      watchedFiles="web.config;*.js"
    />
  </system.webServer>
</configuration>
